# Example Environment Variables for Production Deployment
# Copy this to .env and fill in your values

# ===== BACKEND URL =====
# Your domain where the newsletter will be hosted
BACKEND_URL=https://newsletter.yourdomain.com

# ===== STRIPE (Optional - for supporter subscriptions) =====
# Use test key for testing, live key for production
STRIPE_API_KEY=sk_test_emergent
# STRIPE_API_KEY=sk_live_your_production_key_here

# ===== NOTE =====
# The following are configured through the admin panel Settings page:
# - SendGrid API Key (for email sending)
# - SendGrid Sender Email
# - Bunny.net Storage credentials
# - Admin password (default: admin123)
#
# These are stored in MongoDB, not in environment variables
